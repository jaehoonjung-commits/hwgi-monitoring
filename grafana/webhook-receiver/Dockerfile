FROM python:3.12-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV LOG_LEVEL=INFO
ENV FILE_OUTPUT_PATH=notification_results.log
ENV GMAIL_USER=
ENV GMAIL_APP_PASSWORD=

ENV UMS_API_URL=http://localhost:8000/hwgi/ums/UMSMEMMA020010000
ENV UMS_API_KEY=
ENV UMS_CHNL_SYS_CD=AAA
ENV UMS_IF_ORG_CD=UMS
ENV UMS_APPL_CD=GRFN
ENV UMS_IF_KIND_CD=0100
ENV UMS_IF_TX_CD=10000
ENV UMS_SFTNO=8094310
ENV UMS_ECARD_NO=3402
ENV UMS_CHANNEL=A
ENV UMS_TMPL_TYPE=J
ENV UMS_SENDER_NAME=Grafana
ENV UMS_TIMEOUT_SEC=5

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
